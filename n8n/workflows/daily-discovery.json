    },
    "Normalize — Product Hunt": {
      "main": [[{ "node": "Merge All Discoveries", "type": "main", "index": 0 }]]
    },
    "Hugging Face — New Models": {
      "main": [[{ "node": "Normalize — HuggingFace", "type": "main", "index": 0 }]]
    },
    "Normalize — HuggingFace": {
      "main": [[{ "node": "Merge All Discoveries", "type": "main", "index": 1 }]]
    },
    "GitHub — New AI Repos": {
      "main": [[{ "node": "Normalize — GitHub", "type": "main", "index": 0 }]]
    },
    "Normalize — GitHub": {
      "main": [[{ "node": "Merge All Discoveries", "type": "main", "index": 2 }]]
    },
    "RSS Feeds — Official Blogs": {
      "main": [[{ "node": "Normalize — RSS Blogs", "type": "main", "index": 0 }]]
    },
    "Normalize — RSS Blogs": {
      "main": [[{ "node": "Merge All Discoveries", "type": "main", "index": 3 }]]
    },
    "Merge All Discoveries": {
      "main": [[{ "node": "Deduplicate & Filter Empty", "type": "main", "index": 0 }]]
    },
    "Deduplicate & Filter Empty": {
      "main": [[{ "node": "Execute — Enrich & Queue", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "avelix" }, { "name": "discovery" }]
}
